# ============================================
# admin_web 환경변수
#
# 아래 두 값만 채우면 admin 대시보드가 Supabase 의 beauty_ai 스키마에서
# 실제 데이터를 읽습니다. 값이 없거나 placeholder 면 목업 데이터로 자동 폴백됩니다.
#
# 사전 준비:
#   1) supabase/migrations/003_admin_demo_schema.sql 를 Supabase SQL Editor 에서 실행
#   2) Settings → API → Exposed schemas 에 `beauty_ai` 추가 (필수)
# ============================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# (선택) 서버 전용 작업이 필요할 때만. 현재 admin 데모는 anon 키 + 읽기 전용 RLS 로 충분합니다.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
