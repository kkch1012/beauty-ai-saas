# Server Configuration
APP_NAME="Beauty AI Synthesis Server"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Device (cuda or cpu)
DEVICE=cuda

# Model Paths
MODEL_BASE=runwayml/stable-diffusion-v1-5
CONTROLNET_MODEL=lllyasviel/control_v11p_sd15_inpaint
IP_ADAPTER_MODEL=h94/IP-Adapter
SAM_CHECKPOINT=models/sam_vit_h.pth
LORA_PATH=models/lora/eyebrow_v1

# Inference Settings
DEFAULT_INFERENCE_STEPS=30
DEFAULT_GUIDANCE_SCALE=7.5
DEFAULT_DENOISE_STRENGTH=0.75
MAX_IMAGE_SIZE=1024

# Supabase (for storage integration)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Redis (for job queue)
REDIS_URL=redis://localhost:6379/0

# Storage
TEMP_DIR=/tmp/beauty_ai
MAX_UPLOAD_SIZE=10485760
